# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=conjunapp

# Backend (host Docker Compose usa el servicio "db")
DATABASE_URL=postgresql+psycopg://postgres:root@db:5432/conjunapp
APP_NAME=ConjunApp API
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8080,http://127.0.0.1:5173,http://127.0.0.1:5174
JWT_SECRET_KEY=change-this-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720
ALLOW_ADMIN_REGISTER=true
SEED_ON_STARTUP=true

# Admin (Vite). Desde el navegador del host apunta a localhost:8000
VITE_API_BASE_URL=http://localhost:8000/api/v1

# App residentes (Flutter Web en :5174). La URL la resuelve el NAVEGADOR, no Docker.
RESIDENT_API_BASE_URL=http://localhost:8000/api/v1

# Produccion (docker-compose.prod.yml):
# ENVIRONMENT=production
# ALLOW_ADMIN_REGISTER=false
# SEED_ON_STARTUP=false
# JWT_SECRET_KEY=<secreto-largo-aleatorio>
# POSTGRES_PASSWORD=<password-fuerte>
# DATABASE_URL=postgresql+psycopg://postgres:<password-fuerte>@db:5432/conjunapp
